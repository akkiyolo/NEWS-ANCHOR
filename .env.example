# NewsAnchor AI — Environment Variables
# Copy this file to .env and fill in your API keys.

# Groq API Key — Used for all LLM/AI logic (chat completions, summarization, analysis)
GROQ_API_KEY="your_groq_api_key_here"

# Google Gemini API Key — Fallback LLM for translation and persona explanations
GOOGLE_API_KEY="your_google_api_key_here"

# Mistral API Key — Optional alternative LLM
MISTRAL_API_KEY="your_mistral_api_key_here"

# ElevenLabs API Key — Text-to-Speech voice synthesis
ELEVEN_LABS_API_KEY="your_elevenlabs_api_key_here"

# NewsData.io API Key — Live news headlines and article search
NEWSDATA_IO_API_KEY="your_newsdata_io_api_key_here"

# Server Configuration
PORT=3001
VITE_API_URL=http://localhost:3001
